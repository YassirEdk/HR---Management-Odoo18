<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- My Time Off form -->
    <record id="hr_leave_employee_readonly_my" model="ir.ui.view">
      <field name="name">hr.leave.employee.readonly.my</field>
      <field name="model">hr.leave</field>
      <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='employee_id']" position="attributes">
          <attribute name="modifiers">{"readonly": true}</attribute>
        </xpath>
      </field>
    </record>

    <!-- Manager form (if used in your menus) -->
    <record id="hr_leave_employee_readonly_manager" model="ir.ui.view">
      <field name="name">hr.leave.employee.readonly.manager</field>
      <field name="model">hr.leave</field>
      <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='employee_id']" position="attributes">
          <attribute name="modifiers">{"readonly": true}</attribute>
        </xpath>
      </field>
    </record>

  </data>
</odoo>
