<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Apply badge colors to all hr.leave tree views -->
  <record id="hr_leave_state_badge_colors_global" model="ir.ui.view">
    <field name="name">hr.leave.state.badge.colors.global</field>
    <field name="model">hr.leave</field>
    <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree_my"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='state']" position="attributes">
        <attribute name="decoration-info">state == 'unconfirmed'</attribute>
        <attribute name="decoration-warning">state in ('confirm','validate1')</attribute>
        <attribute name="decoration-success">state == 'validate'</attribute>
        <attribute name="decoration-danger">state in ('refuse','cancel')</attribute>
      </xpath>
    </field>
  </record>
</odoo>