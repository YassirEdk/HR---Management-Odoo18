<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_manager_inherit_custom" model="ir.ui.view">
        <field name="name">hr.leave.view.form.manager.inherit.custom</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
        <field name="arch" type="xml">


            <!-- Inject the 3 "Autres" boolean fields after request_date_to -->
            <xpath expr="//field[@name='request_date_to']" position="after">
                <field name="x_conge_maternite" widget="boolean_toggle" invisible="x_timeoff_category != 'autres'"/>
                <field name="x_conge_deces"     widget="boolean_toggle" invisible="x_timeoff_category != 'autres'"/>
                <field name="x_conge_mariage"   widget="boolean_toggle" invisible="x_timeoff_category != 'autres'"/>
            </xpath>

        </field>
    </record>
</odoo>