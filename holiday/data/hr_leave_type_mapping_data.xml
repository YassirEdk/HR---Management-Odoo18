<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

  <!-- مثال: Paid Time Off -->
  <record id="hr_holidays.holiday_status_cl" model="hr.leave.type">
    <field name="x_timeoff_category">payee</field>
    <field name="active">True</field>
  </record>

  <!-- مثال: Sick Time Off -->
  <record id="hr_holidays.holiday_status_sl" model="hr.leave.type">
    <field name="x_timeoff_category">maladie</field>
    <field name="active">True</field>
  </record>

  <!-- مثال: Unpaid Time Off -->
  <record id="hr_holidays.holiday_status_unpaid" model="hr.leave.type">
    <field name="x_timeoff_category">impayee</field>
    <field name="active">True</field>
  </record>

</odoo>
