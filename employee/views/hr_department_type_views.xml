<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_department_type_tree" model="ir.ui.view">
        <field name="name">hr.department.type.list</field>
        <field name="model">hr.department.type</field>
        <field name="arch" type="xml">
            <list string="Department Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_hr_department_type_form" model="ir.ui.view">
        <field name="name">hr.department.type.form</field>
        <field name="model">hr.department.type</field>
        <field name="arch" type="xml">
            <form string="Department Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_department_type" model="ir.actions.act_window">
        <field name="name">Department Types</field>
        <field name="res_model">hr.department.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a department type
            </p>
            <p>
                Department types drive shifts and attendance grouping.
                The <b>Code</b> is the stored technical value — keep it
                lowercase with no spaces.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_hr_department_type"
        name="Department Types"
        parent="hr.menu_hr_root"
        action="action_hr_department_type"
        sequence="90"
        groups="hr.group_hr_manager,employee.group_employee_hr"/>

</odoo>
