<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Daily cron: période d'essai warnings -->
    <record id="ir_cron_check_periode_essai" model="ir.cron">
        <field name="name">Check Période d'Essai Warnings</field>
        <field name="model_id" ref="model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_periode_essai()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>