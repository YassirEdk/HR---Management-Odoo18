<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- ═══════════════════════════════════════════════════════
         CRON 2: Auto-close missing checkouts (runs at midnight)
    ══════════════════════════════════════════════════════════ -->
    <record id="cron_close_missing_checkout" model="ir.cron">
        <field name="name">Attendance: Close Missing Checkouts</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model.cron_close_missing_checkout()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="priority">10</field>
        <field name="nextcall">2026-03-26 00:00:00</field>
    </record>

</odoo>

