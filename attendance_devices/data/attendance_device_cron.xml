<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         CRON 1: Sync all devices every 10 minutes
         (each run disables every device and pulls its full log, so a
          1-minute cadence keeps the devices offline to employees and
          floods the network at scale — 10 min is a safe balance.)
    ══════════════════════════════════════════════════════════ -->
    <record id="cron_sync_all_devices" model="ir.cron">
        <field name="name">Attendance: Sync All Devices</field>
        <field name="model_id" ref="attendance_devices.model_attendance_device"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_devices()</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
        <field name="priority">5</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         CRON 1b: DISABLED. Absences are now generated inline by
         cron_sync_devices (generate_absences=True), exactly like the
         manual "Sync All" button — all under the same advisory lock.
         The separate cron took no lock and raced the sync cron, which
         caused duplicate/lost absent records. Kept here (inactive) so
         the method stays available for a manual run if ever needed.
    ══════════════════════════════════════════════════════════ -->
    <record id="cron_generate_absences" model="ir.cron">
        <field name="name">Attendance: Generate Absences</field>
        <field name="model_id" ref="attendance_devices.model_attendance_device"/>
        <field name="state">code</field>
        <field name="code">model.cron_generate_absences()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="False"/>
        <field name="priority">7</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         CRON 1c: Close open absent / time-off records at shift end (hourly)
    ══════════════════════════════════════════════════════════ -->
    <record id="cron_close_absent_records" model="ir.cron">
        <field name="name">Attendance: Close Absent Records</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model.cron_close_absent_records()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
        <field name="priority">9</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         CRON 1d: Refresh time-based statuses (every 15 min)
         Absence après-midi / Retard de pause depend on elapsed time
         but have no @api.depends trigger — recompute today's real
         records so they appear as soon as the grace elapses.
    ══════════════════════════════════════════════════════════ -->
    <record id="cron_refresh_statuses" model="ir.cron">
        <field name="name">Attendance: Refresh Statuses</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model.cron_refresh_statuses()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
        <field name="priority">8</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         Disable Odoo's native absence detection cron. This module
         fully owns attendance-absence logic; the native 4h cron only
         adds noise and can conflict. Done as a data record so it
         stays disabled across upgrades.
    ══════════════════════════════════════════════════════════ -->
    <record id="hr_attendance.hr_attendance_absence_cron" model="ir.cron">
        <field name="active" eval="False"/>
    </record>

</odoo>