<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_overview_wizard_form" model="ir.ui.view">
        <field name="name">attendance.overview.wizard.form</field>
        <field name="model">attendance.overview.wizard</field>
        <field name="arch" type="xml">
            <form string="Voir une date">
                <sheet>

                    <!-- Date picker -->
                    <div class="oe_title">
                        <label for="date" string="📅 Choisir une date"/>
                        <h2>
                            <field name="date" widget="date"/>
                        </h2>
                    </div>

                    <div class="o_row mb-4">
                        <button name="action_pick_date" type="object"
                                string="🔍 Voir toutes les presences"
                                class="btn-primary"/>
                    </div>

                    <div class="o_button_box" name="button_box">

                        <button name="action_view_bucket" type="object"
                                context="{'bucket_code': 'on_time'}"
                                invisible="total_present == 0"
                                class="o_stat_button" icon="fa-check-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-success">
                                    <field name="total_present" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">À l'heure</span>
                            </div>
                        </button>

                        <button name="action_view_bucket" type="object"
                                context="{'bucket_code': 'late'}"
                                invisible="total_late == 0"
                                class="o_stat_button" icon="fa-clock-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-warning">
                                    <field name="total_late" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Retard</span>
                            </div>
                        </button>

                        <button name="action_view_bucket" type="object"
                                context="{'bucket_code': 'late_break'}"
                                invisible="total_late_break == 0"
                                class="o_stat_button" icon="fa-hourglass-half">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-warning">
                                    <field name="total_late_break" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Retard de pause</span>
                            </div>
                        </button>

                        <button name="action_view_bucket" type="object"
                                context="{'bucket_code': 'absence'}"
                                invisible="total_absent == 0"
                                class="o_stat_button" icon="fa-times-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-danger">
                                    <field name="total_absent" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Absence</span>
                            </div>
                        </button>

                        <button name="action_view_bucket" type="object"
                                context="{'bucket_code': 'timeoff'}"
                                invisible="total_timeoff == 0"
                                class="o_stat_button" icon="fa-plane">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-info">
                                    <field name="total_timeoff" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Congé</span>
                            </div>
                        </button>

                        <button name="action_view_bucket" type="object"
                                context="{'bucket_code': 'missing_checkout'}"
                                invisible="total_autres == 0"
                                class="o_stat_button" icon="fa-question-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-muted">
                                    <field name="total_autres" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Missing Checkout</span>
