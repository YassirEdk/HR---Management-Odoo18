<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_overview_wizard_form" model="ir.ui.view">
        <field name="name">attendance.overview.wizard.form</field>
        <field name="model">attendance.overview.wizard</field>
        <field name="arch" type="xml">
            <form string="Pick a date">
                <sheet>

                    <!-- Date picker -->
                    <div class="oe_title">
                        <label for="date" string="📅 Choisir une date"/>
                        <h2>
                            <field name="date" widget="date"/>
                        </h2>
                    </div>

                    <div class="o_row mb-4">
                        <button name="action_pick_date" type="object"
                                string="🔍 Voir toutes les presences"
                                class="btn-primary"/>
                    </div>

                    <!-- Global totals -->
                    <div class="o_button_box" name="button_box">

                        <button name="action_view_present" type="object"
                                class="o_stat_button" icon="fa-check-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-success">
                                    <field name="total_present" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">A l'heure</span>
                            </div>
                        </button>

                        <button name="action_view_late" type="object"
                                class="o_stat_button" icon="fa-clock-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-warning">
                                    <field name="total_late" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">En retard</span>
                            </div>
                        </button>

                        <button name="action_view_absent" type="object"
                                class="o_stat_button" icon="fa-times-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-danger">
                                    <field name="total_absent" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Absent</span>
                            </div>
                        </button>

                        <button name="action_view_autres" type="object"
                                class="o_stat_button" icon="fa-question-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-muted">
                                    <field name="total_autres" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Autres</span>
                            </div>
                        </button>

                    </div>

                    <separator string="Siège"/>
                    <div class="o_button_box" name="siege_box">

                        <button name="action_siege_present" type="object"
                                class="o_stat_button" icon="fa-check-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-success">
                                    <field name="siege_present" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">A l'heure</span>
                            </div>
                        </button>

                        <button name="action_siege_late" type="object"
                                class="o_stat_button" icon="fa-clock-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-warning">
                                    <field name="siege_late" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">En retard</span>
                            </div>
                        </button>

                        <button name="action_siege_absent" type="object"
                                class="o_stat_button" icon="fa-times-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-danger">
                                    <field name="siege_absent" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Absent</span>
                            </div>
                        </button>

                        <button name="action_siege_autres" type="object"
                                class="o_stat_button" icon="fa-question-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-muted">
                                    <field name="siege_autres" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Autres</span>
                            </div>
                        </button>

                    </div>

                    <separator string="Agence"/>
                    <div class="o_button_box" name="agence_box">

                        <button name="action_agence_present" type="object"
                                class="o_stat_button" icon="fa-check-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-success">
                                    <field name="agence_present" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">A l'heure</span>
                            </div>
                        </button>

                        <button name="action_agence_late" type="object"
                                class="o_stat_button" icon="fa-clock-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-warning">
                                    <field name="agence_late" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">En retard</span>
                            </div>
                        </button>

                        <button name="action_agence_absent" type="object"
                                class="o_stat_button" icon="fa-times-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-danger">
                                    <field name="agence_absent" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Absent</span>
                            </div>
                        </button>

                        <button name="action_agence_autres" type="object"
                                class="o_stat_button" icon="fa-question-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-muted">
                                    <field name="agence_autres" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Autres</span>
                            </div>
                        </button>

                    </div>

                    <separator string="Warehouse"/>
                    <div class="o_button_box" name="warehouse_box">

                        <button name="action_warehouse_present" type="object"
                                class="o_stat_button" icon="fa-check-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-success">
                                    <field name="warehouse_present" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">A l'heure</span>
                            </div>
                        </button>

                        <button name="action_warehouse_late" type="object"
                                class="o_stat_button" icon="fa-clock-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-warning">
                                    <field name="warehouse_late" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">En retard</span>
                            </div>
                        </button>

                        <button name="action_warehouse_absent" type="object"
                                class="o_stat_button" icon="fa-times-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-danger">
                                    <field name="warehouse_absent" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Absent</span>
                            </div>
                        </button>

                        <button name="action_warehouse_autres" type="object"
                                class="o_stat_button" icon="fa-question-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-muted">
                                    <field name="warehouse_autres" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Autres</span>
                            </div>
                        </button>

                    </div>

                    <separator string="Aéroport"/>
                    <div class="o_button_box" name="aeroport_box">

                        <button name="action_aeroport_present" type="object"
                                class="o_stat_button" icon="fa-check-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-success">
                                    <field name="aeroport_present" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">A l'heure</span>
                            </div>
                        </button>

                        <button name="action_aeroport_late" type="object"
                                class="o_stat_button" icon="fa-clock-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-warning">
                                    <field name="aeroport_late" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">En retard</span>
                            </div>
                        </button>

                        <button name="action_aeroport_absent" type="object"
                                class="o_stat_button" icon="fa-times-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-danger">
                                    <field name="aeroport_absent" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Absent</span>
                            </div>
                        </button>

                        <button name="action_aeroport_autres" type="object"
                                class="o_stat_button" icon="fa-question-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-muted">
                                    <field name="aeroport_autres" readonly="1" nolabel="1"/>
                                </span>
                                <br/><span class="o_stat_text">Autres</span>
                            </div>
                        </button>

                    </div>

                </sheet>
                <footer>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_overview_wizard" model="ir.actions.act_window">
        <field name="name">Pick a date</field>
        <field name="res_model">attendance.overview.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_date': False}</field>
    </record>

    <menuitem
        id="menu_attendance_overview_wizard"
        name="Pick a date"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_attendance_overview_wizard"
        sequence="6"/>

</odoo>