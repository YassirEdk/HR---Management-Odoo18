<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= DEVICE FORM ================= -->
    <record id="view_attendance_device_form" model="ir.ui.view">
        <field name="name">attendance.device.form</field>
        <field name="model">attendance.device</field>
        <field name="arch" type="xml">
            <form string="Appareil">
                <header>
                    <button name="action_sync_device"
                            type="object"
                            string="Synchroniser maintenant"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <field name="is_device_admin" invisible="1"/>
                    <widget name="web_ribbon" title="Hors service" bg_color="text-bg-danger"
                            invisible="device_state != 'out'"/>
                    <group>
                        <group string="Connexion">
                            <field name="name" readonly="not is_device_admin"/>
                            <field name="ip_address" readonly="not is_device_admin"/>
                            <field name="port" readonly="not is_device_admin"/>
                            <field name="location" readonly="not is_device_admin"/>
                            <field name="timezone" readonly="not is_device_admin"/>
                            <field name="department_type" readonly="not is_device_admin"/>
                            <field name="last_sync" readonly="not is_device_admin"/>
                        </group>
                        <!-- ISO 9001 §7.1.5.2 : identification de l'instrument de
                             mesure et preuve de sa vérification périodique. -->
                        <group string="Instrument de mesure (ISO 9001 §7.1.5)">
                            <field name="serial_number" readonly="not is_device_admin"/>
                            <field name="device_model" readonly="not is_device_admin"/>
                            <field name="responsible_id"/>
                            <field name="device_state" readonly="not is_device_admin"/>
                            <field name="clock_drift_tolerance" readonly="not is_device_admin"/>
                            <field name="clock_status"
                                   decoration-danger="clock_status == 'drift'"
                                   decoration-success="clock_status == 'ok'"
                                   decoration-muted="clock_status == 'unknown'"
                                   widget="badge"/>
                            <field name="last_clock_drift"/>
                            <field name="last_clock_check"/>
                        </group>
                    </group>
                    <group string="Paramètres de shift">
                        <field name="night_shift_cutoff" widget="float_time"/>
                    </group>
                    <group string="Détection des absences">
                        <field name="absence_lookback_days"/>
                        <field name="late_threshold_minutes" string="Absent après (minutes après le début du shift)"/>
                    </group>
                    <notebook>
                        <page string="Journal de synchronisation">
                            <field name="sync_log_ids" readonly="1">
                                <list decoration-danger="state == 'failed'"
                                      decoration-warning="state == 'partial'">
                                    <field name="sync_date"/>
                                    <field name="state"/>
                                    <field name="trigger"/>
                                    <field name="records_read"/>
                                    <field name="audit_issues"/>
                                    <field name="unlinked_badges"/>
                                    <field name="clock_drift_seconds"/>
                                    <field name="error_message" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= DEVICE LIST ================= -->
    <record id="view_attendance_device_list" model="ir.ui.view">
        <field name="name">attendance.device.list</field>
        <field name="model">attendance.device</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_sync_selected" type="object"
                            string="Sync les appareils" class="btn-primary"/>
                </header>
                <field name="name"/>
                <field name="department_type"/>
                <field name="ip_address"/>
                <field name="port"/>
                <field name="location"/>
                <field name="last_sync"/>
                <field name="clock_status" widget="badge"
                       decoration-danger="clock_status == 'drift'"
                       decoration-success="clock_status == 'ok'"
                       decoration-muted="clock_status == 'unknown'"/>
                <field name="device_state"/>
            </list>
        </field>
    </record>

    <!-- ================= DEVICE ACTION ================= -->
    <record id="action_attendance_device" model="ir.actions.act_window">
        <field name="name">Appareils</field>
        <field name="res_model">attendance.device</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================= SYNC RESULT WIZARD ================= -->
    <record id="view_attendance_device_sync_wizard_form" model="ir.ui.view">
        <field name="name">attendance.device.sync.wizard.form</field>
        <field name="model">attendance.device.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Résultats Synchronisation" create="false" edit="false">
                <sheet>
                    <group>
                        <field name="message" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Fermer"
                            class="btn-primary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ================= MENU ================= -->
    <menuitem id="menu_attendance_device"
              name="Appareils"
              parent="hr_attendance.menu_hr_attendance_root"
              action="action_attendance_device"
              sequence="15"
              groups="attendance_devices.group_attendance_device_hr,attendance_devices.group_attendance_device_admin,employee.group_employee_hr,base.group_system"/>

</odoo>